---
const clone = 'git clone https://github.com/itoonx/Auralis'
---

<!-- the ambient field (canvas + grid) lives in Field.astro, outside the
     ScrollSmoother content wrapper — a transformed ancestor would break its
     position:fixed. the hero-* classes are animation hooks for Motion.astro:
     the H1 stays transform-only (it's the LCP element and must paint). -->
<!-- content-driven height, NOT min-h-svh centering: the replay terminal
     follows right below, and svh-centering made the note→terminal gap a
     function of viewport slack (covered the note on narrow screens, drifted
     apart on wide ones). fixed paddings keep that gap constant everywhere. -->
<header id="hero" class="relative">
  <div class="relative mx-auto w-full max-w-6xl px-6 pb-14 pt-36 md:pb-16 md:pt-44">
    <p class="hero-kicker flex items-center gap-3 font-mono text-xs tracking-widest text-lp-muted">
      <span class="h-px w-10 bg-lp-accent"></span>
      auralis · the coordination layer for agent fleets
    </p>
    <h1 class="mt-6 max-w-4xl text-balance font-serif text-6xl font-medium lowercase leading-none tracking-tight text-lp-fg md:text-7xl lg:text-8xl">
      the model isn't the bottleneck.
      <span class="block font-light italic text-lp-muted">your shared state is.</span>
    </h1>
    <p class="hero-copy mt-6 max-w-xl text-pretty text-lp-muted">
      we timed it: the LLM call is 99.9% of a fleet's wall-clock; coordination adds ~2.4ms. auralis
      makes shared state explicit, persistent, and never accidental — one brain, every agent, any
      runtime.
    </p>

    <div class="hero-ctas mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
      <!-- the command stays put; a copy icon on the right flips to a check on
           click. the sr-only live region announces the copy (WCAG 4.1.3) so
           screen-reader users get the same confirmation the icon gives. -->
      <button
        id="clone-cta"
        type="button"
        data-cmd={clone}
        class="group flex w-fit cursor-pointer items-center gap-3 rounded border border-lp-border bg-lp-surface/80 px-5 py-3 font-mono text-sm text-lp-fg backdrop-blur transition-colors hover:border-lp-muted"
        title="copy to clipboard">
        <span>$ {clone}</span>
        <span class="relative inline-flex size-4 shrink-0" aria-hidden="true">
          <svg id="clone-copy" class="absolute inset-0 size-4 text-lp-muted transition-opacity group-hover:text-lp-fg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="11" height="11" rx="2" /><path d="M5 15V5a2 2 0 0 1 2-2h10" />
          </svg>
          <svg id="clone-check" class="absolute inset-0 size-4 text-lp-accent opacity-0 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5" />
          </svg>
        </span>
        <span id="clone-status" class="sr-only" aria-live="polite"></span>
      </button>
    </div>
    <p class="hero-note mt-3 font-mono text-xs text-lp-muted">
      running in five commands · no API key — workers reuse your Claude Code login
    </p>
  </div>
</header>

<script>
  // copy-command CTA — the command text stays; only the trailing icon swaps
  // copy → check for 1.2s. the sr-only status region announces it for AT.
  const cta = document.getElementById('clone-cta') as HTMLButtonElement | null
  const copyIcon = document.getElementById('clone-copy')
  const checkIcon = document.getElementById('clone-check')
  const status = document.getElementById('clone-status')
  if (cta && copyIcon && checkIcon) {
    let revert = 0
    cta.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(cta.dataset.cmd!)
        copyIcon.classList.add('opacity-0')
        checkIcon.classList.remove('opacity-0')
        if (status) status.textContent = 'copied to clipboard'
        clearTimeout(revert)
        revert = window.setTimeout(() => {
          copyIcon.classList.remove('opacity-0')
          checkIcon.classList.add('opacity-0')
          if (status) status.textContent = ''
        }, 1200)
      } catch {
        /* clipboard unavailable — the command is selectable text either way */
      }
    })
  }
</script>
