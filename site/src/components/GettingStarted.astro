---
import Section from './Section.astro'

const steps = [
  {
    label: 'install & test',
    cmd: 'git clone https://github.com/itoonx/Auralis && cd Auralis\npnpm install && pnpm test',
    note: 'prerequisites: node 20+ · pnpm · bun ≥ 1.2 · docker (daemon stack only) · claude code logged in',
  },
  {
    label: 'start the daemon',
    cmd: 'node bin/auralis.mjs start',
    note: 'the daemon — studio → localhost:47780 · brain api → :47778. no docker? every command boots a temporary brain itself.',
  },
  {
    label: 'analyze a repository',
    cmd: 'AURALIS_PROJECT=myrepo AURALIS_PROJECT_DIR=/path/to/repo \\\npnpm analyze "how does auth work?"',
    note: 'point a society at any repository — it analyses together, sharing one brain.',
  },
  {
    label: 'build into an empty folder',
    cmd: 'AURALIS_MODE=build AURALIS_ACCEPT=restapi AURALIS_PROJECT_DIR=./my-app \\\nAURALIS_GOAL="a todo REST API over Node\'s http" pnpm dev',
    note: 'or point it at an empty folder and the fleet builds one — verified by an independent harness.',
  },
  {
    label: 'watch it work',
    cmd: 'open http://localhost:47780',
    note: 'live timeline (▸ ✓ ⇄ ↻), run scorecards, the knowledge graph.',
  },
]
---

<Section id="install" title="running in five commands">
  <!-- a rail of mini terminals: number nodes ride a vertical line (md+),
       every command block carries its own copy button (hero's ✓ vocabulary) -->
  <ol class="flex flex-col gap-5 md:border-l md:border-lp-border md:pl-10">
    {steps.map((s, i) => (
      <li class="relative">
        <span
          class="absolute -left-[53px] top-2 hidden h-6 w-6 items-center justify-center rounded-full border border-lp-border bg-lp-bg font-mono text-[10px] text-lp-muted md:flex"
          aria-hidden="true">{i + 1}</span>
        <div class="overflow-hidden rounded-xl border border-lp-border bg-lp-surface transition-colors hover:border-lp-muted/40">
          <div class="flex items-center gap-3 border-b border-lp-border bg-lp-surface-2/80 px-4 py-2">
            <span class="truncate font-mono text-xs text-lp-muted">{String(i + 1).padStart(2, '0')} · {s.label}</span>
            <!-- aria-live: the ✓ copied swap is a status message (WCAG 4.1.3) -->
            <button
              type="button"
              data-cmd={s.cmd}
              aria-live="polite"
              title="copy to clipboard"
              class="ml-auto shrink-0 cursor-pointer rounded border border-lp-border bg-lp-surface px-2.5 py-1 font-mono text-[11px] text-lp-muted transition-colors hover:border-lp-muted hover:text-lp-fg">copy</button>
          </div>
          <pre class="overflow-x-auto px-4 pt-3.5 font-mono text-[13px] leading-6 text-lp-fg"><code><span class="text-lp-accent" aria-hidden="true">$ </span>{s.cmd}</code></pre>
          <p class="px-4 pb-4 pt-2 font-mono text-xs text-lp-muted">{s.note}</p>
        </div>
      </li>
    ))}
  </ol>
  <!-- the two questions every adopter asks before running step 1 — answered
       from the code, not marketing: fleet.ts (planner/workers are Claude Code
       sessions), oracle-lite/server.ts (binds 127.0.0.1), platform.md (local
       embeddings). inline <span>s stay on one line with spaces on both sides —
       the minifier eats newline-only gaps next to tags -->
  <div class="mt-10 grid gap-4 sm:grid-cols-2">
    <div class="rounded-2xl border border-lp-border bg-lp-surface p-6 transition-colors hover:border-lp-muted/40">
      <h3 class="font-mono text-sm text-lp-fg">▸ what it costs</h3>
      <p class="mt-2 text-pretty text-sm leading-6 text-lp-muted">
        no API key, no second subscription: the planner and every worker are plain Claude Code
        sessions on the login you already have — a fleet run spends that login's usage, and the
        spend scales with the workers you ask for. coordination itself (<span class="font-mono text-lp-fg">claim · learn · search</span>) is
        local HTTP at ~2.4ms per event, not extra model calls.
      </p>
    </div>
    <div class="rounded-2xl border border-lp-border bg-lp-surface p-6 transition-colors hover:border-lp-muted/40">
      <h3 class="font-mono text-sm text-lp-fg">▸ where your code goes</h3>
      <p class="mt-2 text-pretty text-sm leading-6 text-lp-muted">
        the brain is a SQLite file on your disk (plus an optional local vector index) and it binds
        to <span class="font-mono text-lp-fg">127.0.0.1</span> only; embeddings are computed
        locally. nothing leaves your machine beyond what your agents already send to the model —
        no telemetry, no analytics. sharing the studio is an explicit <span class="font-mono text-lp-fg">--share</span> opt-in.
      </p>
    </div>
  </div>
  <p class="mt-8 text-pretty text-sm text-lp-muted">
    point auralis at a repository and a society of agents analyses it together; point it at an
    empty folder and they build one — the same coordination either way.
  </p>
</Section>

<script>
  // one handler wires every per-step copy button — same 800ms ✓ as the hero
  document.querySelectorAll<HTMLButtonElement>('#install button[data-cmd]').forEach((btn) => {
    const original = btn.textContent
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.cmd!)
        btn.textContent = '✓ copied'
        btn.classList.add('text-lp-accent')
        setTimeout(() => {
          btn.textContent = original
          btn.classList.remove('text-lp-accent')
        }, 800)
      } catch {
        /* clipboard unavailable — the command is selectable text either way */
      }
    })
  })
</script>
