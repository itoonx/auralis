---
// The studio's runs page, recreated from the recorded run: the run ledger row
// (scorecard: tasks · overlaps · findings · events), the run detail, and
// events-by-worker bars. Every number is computed from the export.
import { runData, fmtOffset, shortRunId } from '../../lib/run'
import KindChip from './KindChip.astro'

const d = runData.derived
const last = runData.events[runData.events.length - 1]
const wall = fmtOffset(last.t)

const workers = [...new Set(runData.events.filter((e) => e.kind === 'intent').map((e) => e.actor))]
const byWorker = workers
  .map((w) => ({ w, n: runData.events.filter((e) => e.actor === w).length }))
  .sort((a, b) => b.n - a.n)
const maxN = byWorker[0].n

const moments = runData.events.filter((e) => e.kind !== 'trace' && e.text).slice(-3)
const strip = (t: string) => t.replace(/^\S+\s*/, '')
const short = (s: string, n = 24) => (s.length > n ? `${s.slice(0, n - 1)}…` : s)
---

<div class="space-y-3 p-3 sm:p-3.5">
  <p class="sr-only">
    the studio's runs page, recreated from the recorded run: the ledger row reads {d.byKind.intent}{' '}
    tasks, {d.overlapsFlagged} overlaps, {d.byKind.finding} findings, {runData.eventCount} events over
    a {wall} wall clock
  </p>
      <div class="st-card overflow-hidden" aria-hidden="true">
        <div class="grid grid-cols-[minmax(0,1fr)_repeat(4,auto)] items-center gap-x-3 px-3.5 py-2 text-[10.5px] text-(--muted-foreground) sm:gap-x-4">
          <span>run</span><span>tasks</span><span>overlaps</span><span>findings</span><span>events</span>
        </div>
        <div class="st-selected grid grid-cols-[minmax(0,1fr)_repeat(4,auto)] items-center gap-x-3 px-3.5 py-2.5 text-xs tabular-nums sm:gap-x-4">
          <span class="min-w-0">
            <span class="flex items-center gap-1.5">
              <span class="truncate font-mono">{shortRunId(runData.runId)}</span>
              <span class="st-viewing shrink-0 rounded px-1.5 py-px text-[9.5px]">viewing</span>
            </span>
            <span class="font-mono text-[10px] text-(--muted-foreground)">{runData.recordedAt.slice(0, 10)}</span>
          </span>
          <span>{d.byKind.intent}</span>
          <span class="font-medium text-(--destructive)">{d.overlapsFlagged}</span>
          <span class="text-(--primary)">{d.byKind.finding}</span>
          <span>{runData.eventCount}</span>
        </div>
      </div>

      <div class="st-card">
        <div class="flex flex-wrap items-center gap-1.5 px-3.5 pt-3 pb-2">
          <h4 class="text-sm font-semibold">run detail</h4>
          <span class="st-badge">events {runData.eventCount}</span>
          <span class="st-badge">wall {wall}</span>
        </div>
        <ol class="border-t border-(--border)">
          {moments.map((e) => (
            <li class="flex items-center gap-2.5 border-b border-(--border) px-3.5 py-1.5 text-xs">
              <span class="font-mono text-[10.5px] text-(--muted-foreground) tabular-nums">{fmtOffset(e.t)}</span>
              <KindChip kind={e.kind} />
              <span class="min-w-0 truncate text-(--muted-foreground)">{strip(e.text ?? '')}</span>
            </li>
          ))}
        </ol>
        <div class="st-bars space-y-1.5 px-3.5 py-3">
          <p class="text-[11px] text-(--muted-foreground)">events by worker · share of the busiest</p>
          {byWorker.map(({ w, n }, i) => (
            <div class="flex items-center gap-2">
              <span class="w-36 shrink-0 truncate font-mono text-[10.5px] text-(--muted-foreground)" title={w}>{short(w)}</span>
              <span class="relative h-1.5 min-w-0 flex-1 overflow-hidden rounded-full bg-(--secondary)">
                <span class="st-bar-fill absolute inset-y-0 left-0 rounded-full bg-(--primary)" style={`width: ${Math.round((n / maxN) * 100)}%; animation-delay: ${i * 0.09}s`}></span>
              </span>
              <span class="w-5 shrink-0 text-right font-mono text-[10.5px] tabular-nums">{n}</span>
            </div>
          ))}
        </div>
      </div>
</div>

<style>
  /* bars draw to their share every time the runs tab is shown — [hidden]
     toggling restarts the CSS animation, so no scroll-trigger is needed */
  .st-bar-fill {
    animation: st-grow 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes st-grow {
    from { clip-path: inset(0 100% 0 0); }
    to { clip-path: inset(0 0 0 0); }
  }
  .st-selected {
    background: color-mix(in oklab, var(--primary) 8%, transparent);
    box-shadow: inset 0 0 0 2px color-mix(in oklab, var(--primary) 45%, transparent);
    border-radius: 0 0 0.7rem 0.7rem;
  }
  .st-viewing {
    color: var(--primary);
    background: color-mix(in oklab, var(--primary) 14%, transparent);
  }
  .st-badge {
    border-radius: 0.375rem;
    background: var(--secondary);
    color: var(--muted-foreground);
    padding: 0 0.4rem;
    font-size: 10px;
    line-height: 1.7;
    font-family: var(--font-mono);
  }
</style>
