---
// The single studio window, framed like a real browser: a tab strip (macOS
// traffic lights + one tab) over a toolbar (back / forward / reload + an
// address bar reading localhost:47780). The browser chrome follows the
// VISITOR'S SYSTEM theme via prefers-color-scheme — light chrome on a light
// OS, dark on a dark one — so it reads as their own browser. The app inside
// stays dark (the studio ships dark-only).
//
// Inside the frame: the studio's own slim header, then its left rail as a
// real tablist — clicking overview / runs / graph swaps the recreated page.
// Auto-tour advances the tab every 5s (a hairline under the active rail item
// counts it down); any manual interaction ends it; reduced motion never
// starts it.
//
// The app subtree is wrapped in class="dark" so it resolves the variables
// from tokens.css's .dark block — the SAME file CI keeps a verbatim copy of
// dashboard/src/index.css. The mock literally cannot drift from the shipped
// studio theme.
import { runData } from '../../lib/run'
import { ICON } from './icons'

const tabs = ['overview', 'runs', 'graph'] as const
const inert = ['decisions', 'search'] as const
const clock = runData.finishedAt.slice(11, 19)
const pill = `Auralis · ${runData.derived.byKind.finding} findings · ${runData.eventCount} events`
---

<div class="st-window">
  {/* ── browser chrome — commented out per request; uncomment through the matching </div> below to restore ──
  <div class="st-bx" aria-hidden="true">
    <div class="st-bx-strip">
      <span class="st-lights">
        <span></span><span></span><span></span>
      </span>
      <span class="st-bx-tab">
        <svg viewBox="0 0 24 24" class="size-3.5 shrink-0 text-(--primary)" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={ICON.logo} />
        <span class="min-w-0 flex-1 truncate">auralis · studio</span>
        <svg viewBox="0 0 24 24" class="st-bx-x size-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={ICON.x} />
      </span>
      <svg viewBox="0 0 24 24" class="st-bx-btn size-6 shrink-0 p-1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={ICON.plus} />
    </div>
    <div class="st-bx-bar">
      <svg viewBox="0 0 24 24" class="st-bx-btn size-7 shrink-0 p-1.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICON.back} />
      <svg viewBox="0 0 24 24" class="st-bx-btn st-bx-off size-7 shrink-0 p-1.5 max-sm:hidden" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICON.forward} />
      <svg viewBox="0 0 24 24" class="st-bx-btn size-7 shrink-0 p-1.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICON.reload} />
      <span class="st-bx-url">
        <svg viewBox="0 0 24 24" class="size-3.5 shrink-0 opacity-70" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={ICON.info} />
        <span class="min-w-0 flex-1 truncate"><span class="st-bx-dim">localhost:</span>47780</span>
        <svg viewBox="0 0 24 24" class="size-3.5 shrink-0 opacity-70 max-sm:hidden" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={ICON.star} />
      </span>
      <svg viewBox="0 0 24 24" class="st-bx-btn size-7 shrink-0 p-1.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" set:html={ICON.menu} />
    </div>
  </div>
  ── end browser chrome */}

  {/* ── the app (dark) ──────────────────────────────────────────────────── */}
  <div class="st-app dark">
    <div class="st-appbar flex items-center gap-2 border-b px-3.5 py-2 sm:gap-3 sm:px-4" aria-hidden="true">
      <span class="flex items-center gap-1.5">
        <svg viewBox="0 0 24 24" class="size-4 text-(--primary)" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICON.logo} />
        <span class="text-[13px] font-semibold tracking-tight text-(--foreground)">auralis</span>
        <span class="text-[13px] text-(--muted-foreground)">· studio</span>
      </span>
      <span class="st-pill ml-auto hidden items-center gap-1.5 rounded-md border px-2 py-1 text-[11px] sm:flex">
        {pill}
        <svg viewBox="0 0 24 24" class="size-3 opacity-60" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m7 9 5-5 5 5M7 15l5 5 5-5"/></svg>
      </span>
      <span class="st-live ml-auto flex items-center gap-1.5 rounded-md px-2 py-1 text-[11px] font-medium sm:ml-0">
        <span class="st-live-dot size-1.5 rounded-full bg-current"></span>live
      </span>
      <span class="hidden font-mono text-[11px] text-(--muted-foreground) md:inline" title={`recorded ${runData.recordedAt.slice(0, 10)}`}>{clock}</span>
    </div>

    <div class="flex">
      <div
        class="st-rail flex w-11 shrink-0 flex-col gap-1 border-r p-1.5 sm:w-36 sm:p-2"
        role="tablist"
        aria-label="studio pages"
        aria-orientation="vertical"
      >
        {tabs.map((p, i) => (
          <button
            type="button"
            role="tab"
            id={`st-tab-${p}`}
            aria-controls={`st-panel-${p}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-page={p}
            class:list={['st-tab', i === 0 && 'st-rail-active']}
            title={p}
          >
            <svg viewBox="0 0 24 24" class="size-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICON[p]} />
            <span class="hidden sm:inline">{p}</span>
            <span class="st-tab-progress" aria-hidden="true"></span>
          </button>
        ))}
        {inert.map((p) => (
          <span class="st-tab opacity-45" title={`${p} — in the live studio`} aria-hidden="true">
            <svg viewBox="0 0 24 24" class="size-3.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICON[p]} />
            <span class="hidden sm:inline">{p}</span>
          </span>
        ))}
      </div>

      <div class="min-w-0 flex-1 md:min-h-[600px]">
        <div class="st-panel" id="st-panel-overview" role="tabpanel" aria-labelledby="st-tab-overview">
          <slot name="overview" />
        </div>
        <div class="st-panel" id="st-panel-runs" role="tabpanel" aria-labelledby="st-tab-runs" hidden>
          <slot name="runs" />
        </div>
        <div class="st-panel" id="st-panel-graph" role="tabpanel" aria-labelledby="st-tab-graph" hidden>
          <slot name="graph" />
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  .st-window {
    border-radius: 0.875rem;
    overflow: hidden;
    box-shadow: 0 24px 64px -32px oklch(0 0 0 / 0.85);
    /* the frame border reads as the browser window edge */
    border: 1px solid oklch(1 0 0 / 0.1);
  }

  /* ── browser chrome ─ its own palette, switched by the SYSTEM theme; the
     landing page forces color-scheme:dark but prefers-color-scheme still
     reflects the real OS setting, which is exactly what we want here ─────── */
  .st-bx {
    /* light chrome (default / prefers light) */
    --bx-strip: #dbdde1;
    --bx-bar: #f4f5f7;
    --bx-tab: #f4f5f7;
    --bx-field: #ffffff;
    --bx-text: #1f2023;
    --bx-icon: #5f6169;
    --bx-border: rgb(0 0 0 / 0.09);
    --bx-hover: rgb(0 0 0 / 0.06);
    background: var(--bx-bar);
    color: var(--bx-text);
    border-bottom: 1px solid var(--bx-border);
  }
  @media (prefers-color-scheme: dark) {
    .st-bx {
      --bx-strip: #17161b;
      --bx-bar: #2a2931;
      --bx-tab: #37363f;
      --bx-field: #1b1a20;
      --bx-text: #e8e8ed;
      --bx-icon: #adadb6;
      --bx-border: rgb(255 255 255 / 0.07);
      --bx-hover: rgb(255 255 255 / 0.08);
    }
  }
  .st-bx-strip {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 0.6rem 0;
    background: var(--bx-strip);
  }
  .st-lights {
    display: flex;
    gap: 0.4rem;
    padding: 0 0.35rem;
  }
  .st-lights span {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
  }
  .st-lights span:nth-child(1) { background: #ff5f57; }
  .st-lights span:nth-child(2) { background: #febc2e; }
  .st-lights span:nth-child(3) { background: #28c840; }
  .st-bx-tab {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
    max-width: 15rem;
    flex: 1 1 auto;
    padding: 0.4rem 0.6rem;
    font-size: 12px;
    border-radius: 0.55rem 0.55rem 0 0;
    background: var(--bx-tab);
    color: var(--bx-text);
  }
  .st-bx-x {
    color: var(--bx-icon);
    border-radius: 999px;
    padding: 1px;
  }
  .st-bx-bar {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.4rem 0.6rem;
    background: var(--bx-bar);
  }
  .st-bx-btn {
    color: var(--bx-icon);
    border-radius: 999px;
  }
  .st-bx-off { opacity: 0.38; }
  .st-bx-url {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
    flex: 1 1 auto;
    margin: 0 0.3rem;
    padding: 0.32rem 0.7rem;
    border-radius: 999px;
    background: var(--bx-field);
    border: 1px solid var(--bx-border);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--bx-text);
  }
  .st-bx-dim { color: var(--bx-icon); }

  /* ── the app body (dark tokens) ──────────────────────────────────────── */
  .st-app {
    background: var(--background);
    color: var(--foreground);
  }
  .st-appbar,
  .st-rail {
    border-color: var(--border);
  }
  .st-pill {
    border-color: var(--border);
    color: var(--muted-foreground);
  }
  .st-live {
    color: var(--primary);
    background: color-mix(in oklab, var(--primary) 12%, transparent);
    border: 1px solid color-mix(in oklab, var(--primary) 30%, transparent);
  }
  .st-live-dot {
    animation: st-pulse 2.2s ease-in-out infinite;
  }
  @keyframes st-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .st-tab {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 0.5rem;
    padding: 0.5rem 0;
    font-size: 12px;
    color: var(--muted-foreground);
    transition: color 0.15s ease-out, background-color 0.15s ease-out;
  }
  @media (min-width: 40rem) {
    .st-tab {
      justify-content: flex-start;
      padding: 0.375rem 0.625rem;
    }
  }
  button.st-tab { cursor: pointer; }
  button.st-tab:hover { color: var(--foreground); }
  button.st-tab:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: -2px;
  }
  .st-rail-active,
  button.st-tab.st-rail-active:hover {
    color: var(--primary);
    background: color-mix(in oklab, var(--primary) 10%, transparent);
  }
  /* auto-tour countdown — a hairline under the active rail item */
  .st-tab-progress {
    position: absolute;
    left: 8px;
    right: 8px;
    bottom: 2px;
    height: 2px;
    border-radius: 999px;
    background: color-mix(in oklab, var(--primary) 55%, transparent);
    transform: scaleX(0);
    transform-origin: left;
  }
  .st-tab-progress.st-on {
    animation: st-tab-fill 5s linear forwards;
  }
  @keyframes st-tab-fill {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }
  .st-card {
    border-radius: 0.75rem;
    border: 1px solid var(--border);
    background: var(--card);
  }
  /* KindChip: icon + word, border-current/20 bg-current/8 — same recipe as
     the studio's KindChip component. */
  .st-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 0;
    border-radius: 0.5rem;
    padding: 0.1rem 0.45rem;
    font-size: 11px;
    line-height: 1.5;
    border: 1px solid color-mix(in oklab, currentColor 20%, transparent);
    background: color-mix(in oklab, currentColor 8%, transparent);
  }
  /* Event-kind data colors — the studio's tailwind palette values. */
  .st-k-phase { color: oklch(0.702 0.183 293.5); }   /* violet-400 */
  .st-k-task { color: oklch(0.707 0.165 254.6); }    /* blue-400 */
  .st-k-tool { color: var(--muted-foreground); }
  .st-k-finding { color: var(--primary); }
  .st-k-overlap { color: var(--destructive); }
</style>

<script>
  // Rail tabs: click (or arrow keys) swaps the recreated page. Panels toggle
  // via [hidden], so CSS animations inside a panel replay each time it is
  // shown — the runs bars re-draw.
  //
  // Auto-tour: while the window is on screen, the active tab advances every
  // 5s (the hairline under the rail item counts it down). Any manual
  // interaction ends the tour for good — the user has taken the wheel.
  // Reduced motion never starts it.
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('button.st-tab[data-page]'))
  const panels = Array.from(document.querySelectorAll<HTMLElement>('.st-panel'))
  const select = (tab: HTMLButtonElement) => {
    for (const t of tabs) {
      const on = t === tab
      t.setAttribute('aria-selected', String(on))
      t.classList.toggle('st-rail-active', on)
    }
    for (const p of panels) p.hidden = p.id !== `st-panel-${tab.dataset.page}`
  }

  let timer = 0
  let touring = !matchMedia('(prefers-reduced-motion: reduce)').matches
  let idx = 0
  const resetProgress = (runningTab?: HTMLButtonElement) => {
    for (const t of tabs) {
      const bar = t.querySelector<HTMLElement>('.st-tab-progress')
      if (!bar) continue
      bar.classList.remove('st-on')
      if (t === runningTab) {
        void bar.offsetWidth // restart the fill animation from zero
        bar.classList.add('st-on')
      }
    }
  }
  const suspendTour = () => {
    clearInterval(timer)
    timer = 0
    resetProgress()
  }
  const resumeTour = () => {
    if (!touring || timer) return
    resetProgress(tabs[idx])
    timer = window.setInterval(() => {
      idx = (idx + 1) % tabs.length
      select(tabs[idx])
      resetProgress(tabs[idx])
    }, 5000)
  }
  const endTour = () => {
    touring = false
    suspendTour()
  }

  tabs.forEach((t, i) => {
    t.addEventListener('click', () => {
      endTour()
      idx = i
      select(t)
    })
    t.addEventListener('keydown', (e) => {
      const dir = e.key === 'ArrowDown' || e.key === 'ArrowRight' ? 1 : e.key === 'ArrowUp' || e.key === 'ArrowLeft' ? -1 : 0
      if (!dir) return
      e.preventDefault()
      endTour()
      idx = (i + dir + tabs.length) % tabs.length
      const next = tabs[idx]
      next.focus()
      select(next)
    })
  })

  // live but calm: the tour only runs while the window is actually on screen
  const win = document.querySelector('.st-window')
  if (win && touring) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) (e.isIntersecting ? resumeTour : suspendTour)()
      },
      { threshold: 0.35 },
    )
    io.observe(win)
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) suspendTour()
      else if (win.getBoundingClientRect().top < innerHeight) resumeTour()
    })
  }
</script>
