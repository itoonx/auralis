---
// The studio's overview page, recreated from the recorded run: stat strip,
// activity feed, findings column. The feed types itself out on scroll —
// decoration only; SSR renders the finished picture (no-JS / reduced-motion
// see everything immediately).
import { runData, fmtOffset } from '../../lib/run'
import KindChip from './KindChip.astro'

const d = runData.derived

// First 7 non-trace beats + the closing phase — a compact slice of the run's
// narrative arc (plan → tasks → findings → overlaps → "run complete").
const beats = runData.events.filter((e) => e.kind !== 'trace' && e.text)
const feed = [...beats.slice(0, 7), beats[beats.length - 1]]

const findings = runData.events.filter((e) => e.kind === 'finding')
const wall = fmtOffset(runData.events[runData.events.length - 1].t)

// The studio strips the leading glyph before the kind chip (one vocabulary,
// stated once).
const strip = (t: string) => t.replace(/^\S+\s*/, '')
const shortActor = (a: string) => (a.length > 18 ? `${a.slice(0, 17)}…` : a)
---

<div class="space-y-3 p-3 sm:p-4">
  <p class="sr-only">
    the studio's overview page, recreated from the recorded run: four stat cards, the live activity
    feed, and the findings column
  </p>
      <div class="grid grid-cols-2 gap-2.5 lg:grid-cols-4" aria-hidden="true">
        <div class="st-card p-3.5">
          <div class="text-2xl leading-none font-semibold tabular-nums">{d.workers}</div>
          <div class="mt-1.5 text-[11px] text-(--muted-foreground)">workers in the fleet</div>
        </div>
        <div class="st-card p-3.5">
          <div class="text-2xl leading-none font-semibold tabular-nums">{d.byKind.intent}</div>
          <div class="mt-1.5 text-[11px] text-(--muted-foreground)">tasks planned · 2 levels</div>
        </div>
        <div class="st-card p-3.5">
          <div class="text-2xl leading-none font-semibold tabular-nums">{d.byKind.finding}</div>
          <div class="mt-1.5 text-[11px] text-(--muted-foreground)">findings written to the brain</div>
        </div>
        <div class="st-card p-3.5">
          <div class="text-2xl leading-none font-semibold text-(--destructive) tabular-nums">{d.overlapsFlagged}</div>
          <div class="mt-1.5 text-[11px] text-(--muted-foreground)">overlaps flagged live</div>
        </div>
      </div>

      <div class="grid gap-3 lg:grid-cols-3">
        <div class="st-card min-w-0 lg:col-span-2">
          <div class="flex flex-wrap items-center justify-between gap-2 px-3.5 pt-3 pb-2">
            <div>
              <h4 class="text-sm font-semibold">activity</h4>
              <p class="text-[11px] text-(--muted-foreground)">wall {wall} · updated {runData.finishedAt.slice(11, 19)}</p>
            </div>
            <div class="flex flex-wrap items-center gap-1.5" aria-hidden="true">
              <span class="st-chip st-k-task">tasks {d.byKind.intent}</span>
              <span class="st-chip st-k-overlap">overlaps {d.overlapsFlagged}</span>
              <span class="st-chip st-k-finding">findings {d.byKind.finding}</span>
              <span class="st-chip text-(--muted-foreground)">tools {d.byKind.trace} hidden</span>
            </div>
          </div>
          <div class="flex items-center gap-1.5 px-3.5 pb-2 font-mono text-[11px] text-(--muted-foreground)">
            <span class="truncate">{runData.runId}</span>
            <svg viewBox="0 0 24 24" class="size-3 shrink-0 opacity-70" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
          </div>
          <ol id="st-feed" class="text-[13px]">
            {feed.map((e) => (
              <li class="st-row flex items-start gap-2.5 border-t border-(--border) px-3.5 py-2">
                <span class="pt-0.5 font-mono text-[11px] text-(--muted-foreground) tabular-nums">{fmtOffset(e.t)}</span>
                <KindChip kind={e.kind} />
                <div class="relative min-w-0 flex-1 leading-5">
                  <span class="invisible block line-clamp-2">{strip(e.text ?? '')}</span>
                  <span class="st-type absolute inset-0 line-clamp-2" aria-hidden="true">{strip(e.text ?? '')}</span>
                  <span class="sr-only">{strip(e.text ?? '')}</span>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div class="st-card min-w-0">
          <div class="px-3.5 pt-3 pb-2">
            <h4 class="text-sm font-semibold">findings <span class="ml-1 text-[11px] font-normal text-(--muted-foreground)">in the brain</span></h4>
          </div>
          <ul>
            {findings.map((e) => (
              <li class="border-t border-(--border) px-3.5 py-2.5">
                <div class="mb-1 flex items-center gap-1.5 text-[10px]">
                  <span class="st-badge">worker·{shortActor(e.actor)}</span>
                  <span class="text-(--muted-foreground)">trust 0.50</span>
                  <span class="ml-auto shrink-0 font-mono text-(--muted-foreground)">{fmtOffset(e.t)}</span>
                </div>
                <p class="line-clamp-3 text-xs leading-4.5 text-(--muted-foreground)">{strip(e.text ?? '').replace(/^\S+:\s*/, '')}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
</div>

<style>
  .st-badge {
    border-radius: 0.375rem;
    background: var(--secondary);
    color: var(--muted-foreground);
    padding: 0 0.4rem;
    line-height: 1.7;
    font-family: var(--font-mono);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

<style is:global>
  /* the caret is created by JS, so it can't carry Astro's scoped attribute */
  .st-caret {
    color: var(--primary);
    margin-left: 1px;
    animation: st-blink 1.1s steps(2, start) infinite;
  }
  @keyframes st-blink {
    50% { opacity: 0; }
  }
</style>

<script>
  // Feed typewriter — decoration time only. SSR ships the finished feed; JS
  // (motion allowed) empties the rows and replays the run as if streaming in.
  // Screen readers always get the full text (.sr-only copy; typed layer is
  // aria-hidden).
  const feed = document.getElementById('st-feed')
  if (feed && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const rows = Array.from(feed.querySelectorAll<HTMLElement>('.st-row'))
    const texts = rows.map((r) => r.querySelector('.st-type')?.textContent ?? '')
    // initial state set from JS, never CSS — no-JS keeps the page readable
    for (const r of rows) {
      r.style.opacity = '0'
      r.style.transform = 'translateY(6px)'
      r.style.transition = 'opacity 0.35s ease-out, transform 0.35s ease-out'
      const t = r.querySelector('.st-type')
      if (t) t.textContent = ''
    }
    const caret = document.createElement('span')
    caret.className = 'st-caret'
    caret.setAttribute('aria-hidden', 'true')
    caret.textContent = '▍'
    const wait = (ms: number) => new Promise((res) => setTimeout(res, ms))
    let started = false
    const play = async () => {
      if (started) return
      started = true
      for (let i = 0; i < rows.length; i++) {
        const row = rows[i]
        const t = row.querySelector('.st-type')
        row.style.opacity = '1'
        row.style.transform = 'none'
        if (!t) continue
        t.append(caret)
        const text = texts[i]
        for (let c = 0; c < text.length; c += 2) {
          caret.before(text.slice(c, c + 2))
          await wait(text.length > 90 ? 4 : 9)
        }
        await wait(150)
      }
      // the caret keeps blinking on the last row — the studio is live
    }
    const io = new IntersectionObserver(
      (entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect()
          void play()
        }
      },
      { threshold: 0.2 },
    )
    io.observe(feed)
  }
</script>
