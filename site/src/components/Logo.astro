---
// the mark: agents orbiting one accent core — the same story as the hero
// sphere and the "four agents, one brain" diagram. inherits currentColor
// for the orbits/satellites; only the core takes the accent.
interface Props {
  class?: string
}
const { class: className } = Astro.props
---

<svg class={className} viewBox="0 0 24 24" fill="none" aria-hidden="true">
  <circle cx="12" cy="12" r="9.25" stroke="currentColor" stroke-width="1.4" opacity=".32" />
  <ellipse cx="12" cy="12" rx="9.25" ry="3.8" transform="rotate(-30 12 12)" stroke="currentColor" stroke-width="1.2" opacity=".5" />
  <g class="lg-orbit">
    <circle cx="16.6" cy="4" r="1.5" fill="currentColor" opacity=".9" />
    <circle cx="3.3" cy="15.2" r="1.3" fill="currentColor" opacity=".6" />
    <circle cx="20.2" cy="16.3" r="1.1" fill="currentColor" opacity=".45" />
  </g>
  <circle class="lg-core text-lp-accent" cx="12" cy="12" r="2.9" fill="currentColor" />
</svg>

<style>
  /* decoration only — the global reduced-motion kill flattens both */
  .lg-orbit {
    transform-box: view-box;
    transform-origin: center;
    animation: lg-orbit 24s linear infinite;
  }
  @keyframes lg-orbit {
    to { transform: rotate(360deg); }
  }
  .lg-core {
    animation: lg-core 3.2s ease-in-out infinite;
  }
  @keyframes lg-core {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }
</style>
