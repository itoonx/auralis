---
import StudioGraph from './studio/StudioGraph.astro'
import StudioOverview from './studio/StudioOverview.astro'
import StudioRuns from './studio/StudioRuns.astro'
import StudioWindow from './studio/StudioWindow.astro'

// The studio itself, right under the hero — one window, a real rail: click
// overview / runs / graph to swap the recreated page. No Section wrapper:
// like the terminal that used to live here, it reads as part of the hero
// composition (no title, no top border; the hero's bottom padding sets the
// gap).
---

<section id="studio" class="relative">
  <div class="mx-auto max-w-6xl px-6 pb-20 md:pb-28">
    <figure class="text-left">
      <StudioWindow>
        <StudioOverview slot="overview" />
        <StudioRuns slot="runs" />
        <StudioGraph slot="graph" />
      </StudioWindow>
      <!-- <figcaption class="mt-2 font-mono text-xs text-lp-muted">
        not a screenshot — the studio rebuilt in html from the run recorded on this page, in the
        exact theme tokens it ships with · the rail switches pages · live at localhost:47780
      </figcaption> -->
    </figure>
  </div>
</section>
