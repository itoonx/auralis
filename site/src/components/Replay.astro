---
import { runData, fmtOffset, recordedDate, shortRunId, transcriptEvents } from '../lib/run'

const events = transcriptEvents(13)
const d = runData.derived
const lastT = events[events.length - 1]?.t ?? 0

// every transcript line opens with its kind glyph (━ ▸ » ✓ ⚠) — split it out
// so the glyph can carry the kind's color while the body stays readable
const parts = (t: string | null) => {
  const raw = (t ?? '').trimStart()
  return { glyph: raw.slice(0, 1), body: raw.slice(1).trimStart() }
}
const glyphColor: Record<string, string> = {
  finding: 'text-lp-accent',
  overlap: 'text-(--lp-warn)',
  phase: 'text-lp-fg',
  intent: 'text-lp-fg',
  trace: 'text-lp-muted',
}
const bodyColor: Record<string, string> = {
  finding: 'text-lp-fg',
  answer: 'text-lp-fg',
  overlap: 'text-lp-fg',
}
---

<!-- no Section wrapper: the terminal window overflows up into the hero —
     it's the first proof you see, poking above the fold — so this section
     carries no title, no top border and no top padding of its own. -->
<section id="replay" class="relative">
  <div class="mx-auto max-w-6xl px-6 pb-20 md:pb-28">
  <!-- The Replay — a real recorded fleet run in a terminal window. SSR renders
       the completed transcript (the no-JS / reduced-motion / crawler version);
       the script below replays it against the log's virtual clock. -->
  <figure class="-mt-14 text-left md:-mt-44">
    <div class="overflow-hidden rounded-xl border border-lp-border bg-lp-bg shadow-[0_24px_80px_-32px_rgb(0_0_0/0.9)]">
      <!-- title bar — window chrome; the traffic lights are decoration -->
      <div class="relative flex items-center gap-4 border-b border-lp-border bg-lp-surface-2/80 px-4 py-2.5">
        <span class="flex items-center gap-2" aria-hidden="true">
          <span class="h-3 w-3 rounded-full bg-(--lp-danger)"></span>
          <span class="h-3 w-3 rounded-full bg-(--lp-warn)"></span>
          <span class="h-3 w-3 rounded-full bg-lp-accent"></span>
        </span>
        <span class="pointer-events-none absolute inset-x-0 hidden text-center font-mono text-xs text-lp-muted md:block">
          auralis — analyze · recorded {recordedDate}
        </span>
        <span class="ml-auto flex items-center font-mono text-xs">
          <button
            id="replay-toggle"
            type="button"
            class="hidden cursor-pointer rounded-md border border-lp-border bg-lp-bg/60 px-2.5 py-1 text-lp-fg transition-colors hover:border-lp-muted/60"></button>
        </span>
      </div>

      <!-- the screen -->
      <div class="flex flex-wrap items-baseline gap-x-2 px-4 pt-3 font-mono text-xs md:text-[13px]">
        <span class="text-lp-accent">❯</span>
        <span class="text-lp-fg">auralis analyze</span>
        <span class="text-lp-muted">· {shortRunId(runData.runId)} · {runData.eventCount} events · {d.workers} workers</span>
        <span id="replay-caret" class="rp-caret" style="display:none" aria-hidden="true">▍</span>
      </div>
      <ol id="replay-list" class="overflow-x-auto px-4 pb-3 pt-2 font-mono text-xs leading-6 md:text-[13px]">
        {events.map((e) => {
          const { glyph, body } = parts(e.text)
          return (
            <li class="whitespace-nowrap" data-t={e.t} data-kind={e.kind} data-v={glyph === '✓' ? '1' : undefined}>
              <span class="text-lp-muted/70">{fmtOffset(e.t)}</span>
              <span class:list={['ml-3', glyphColor[e.kind] ?? 'text-lp-muted']}>{glyph}</span>
              <span class:list={['ml-2', bodyColor[e.kind] ?? 'text-lp-muted']}>
                {body.slice(0, 94)}{body.length > 94 ? '…' : ''}
              </span>
            </li>
          )
        })}
      </ol>

      <!-- virtual-clock progress — direct-mapped in JS, never eased -->
      <div class="h-0.5 w-full bg-lp-border" aria-hidden="true">
        <div id="replay-progress" class="h-full origin-left bg-lp-accent/80" style="transform:scaleX(1)"></div>
      </div>

      <div class="flex flex-wrap items-baseline gap-x-5 gap-y-1 bg-lp-surface-2/50 px-4 py-2.5 font-mono text-xs">
        <span class="text-lp-muted">t+<b id="replay-clock" class="font-normal text-lp-fg">{fmtOffset(lastT)}</b></span>
        <span class="text-lp-muted">findings <b data-counter="finding" class="text-lp-fg">{d.byKind.finding ?? 0}</b></span>
        <span class="text-lp-muted"><span class="text-(--lp-warn)">⚠</span> overlaps <b data-counter="overlap" class="text-lp-fg">{d.overlapsFlagged}</b></span>
        <span class="text-lp-muted"><span class="text-lp-accent">✓</span> verified <b data-counter="verified" class="text-lp-fg">{d.verified}</b></span>
        <span class="ml-auto hidden text-lp-muted sm:inline">counters derived from the events above</span>
      </div>
    </div>
    <figcaption class="mt-2 font-mono text-xs text-lp-muted">
      a real fleet run over this repository — recorded events replayed at 48×, not a mockup
    </figcaption>
  </figure>

  <!-- what you just watched + why it matters — the diagram animates the story
       (findings converge on one brain, an overlap gets flagged, recall flows
       back) and is decoration only; the copy carries the claim. -->
  <div class="rp-lead mt-6 rounded-2xl border border-lp-border bg-lp-surface p-6 transition-colors hover:border-lp-muted/40 md:p-8">
    <div class="grid items-center gap-8 lg:grid-cols-[minmax(280px,380px)_1fr]">
      <div class="text-lp-muted" aria-hidden="true">
        <svg viewBox="0 0 320 190" class="w-full" fill="none" stroke-linecap="round">
          <text x="24" y="14" font-size="9" fill="currentColor" opacity=".55" font-family="var(--font-mono)">your agents</text>
          <text x="118" y="26" font-size="9" fill="currentColor" opacity=".45" font-family="var(--font-mono)">findings →</text>
          <text x="118" y="182" font-size="9" fill="currentColor" opacity=".45" font-family="var(--font-mono)">← recall</text>

          <!-- the fleet -->
          <text x="16" y="37" font-size="8" fill="currentColor" opacity=".5" font-family="var(--font-mono)">w1</text>
          <text x="16" y="79" font-size="8" fill="currentColor" opacity=".5" font-family="var(--font-mono)">w2</text>
          <text x="16" y="121" font-size="8" fill="currentColor" opacity=".5" font-family="var(--font-mono)">w3</text>
          <text x="16" y="163" font-size="8" fill="currentColor" opacity=".5" font-family="var(--font-mono)">w4</text>
          <circle cx="44" cy="34" r="7" stroke="currentColor" stroke-width="1.5" opacity=".7" />
          <circle cx="44" cy="34" r="2.5" fill="currentColor" class="text-lp-fg" opacity=".85" />
          <circle cx="44" cy="76" r="7" stroke="currentColor" stroke-width="1.5" opacity=".7" />
          <circle cx="44" cy="76" r="2.5" fill="currentColor" class="text-lp-fg" opacity=".85" />
          <circle cx="44" cy="118" r="7" stroke="currentColor" stroke-width="1.5" opacity=".7" />
          <circle cx="44" cy="118" r="2.5" fill="currentColor" class="text-lp-fg" opacity=".85" />
          <circle cx="44" cy="160" r="7" stroke="currentColor" stroke-width="1.5" opacity=".7" />
          <circle cx="44" cy="160" r="2.5" fill="currentColor" class="text-lp-fg" opacity=".85" />

          <!-- lanes into the brain -->
          <path d="M52 34 C 140 34, 190 70, 226 88" stroke="currentColor" stroke-width="1" opacity=".22" />
          <path d="M52 76 C 140 76, 180 86, 224 94" stroke="currentColor" stroke-width="1" opacity=".22" />
          <path d="M52 118 C 140 118, 180 108, 224 100" stroke="currentColor" stroke-width="1" opacity=".22" />
          <path d="M52 160 C 140 160, 190 124, 226 106" stroke="currentColor" stroke-width="1" opacity=".22" />

          <!-- one brain -->
          <circle class="rp-ring" cx="252" cy="97" r="26" stroke="currentColor" stroke-width="1" />
          <circle cx="252" cy="97" r="26" stroke="currentColor" stroke-width="1" opacity=".35" />
          <circle cx="252" cy="97" r="16" stroke="currentColor" stroke-width="1.5" class="text-lp-accent" opacity=".6" />
          <circle cx="252" cy="97" r="5" fill="currentColor" class="text-lp-accent" opacity=".95" />
          <text x="252" y="142" text-anchor="middle" font-size="9" fill="currentColor" opacity=".6" font-family="var(--font-mono)">one brain</text>

          <!-- findings travel in; w2 and w3 arrive together and get flagged -->
          <circle class="rp-pulse text-lp-fg" r="3" fill="currentColor" opacity="0" style="offset-path:path('M52 34 C 140 34, 190 70, 226 88')" />
          <circle class="rp-pulse rp-d2 text-lp-fg" r="3" fill="currentColor" opacity="0" style="offset-path:path('M52 76 C 140 76, 180 86, 224 94')" />
          <circle class="rp-pulse rp-d2 text-lp-fg" r="3" fill="currentColor" opacity="0" style="offset-path:path('M52 118 C 140 118, 180 108, 224 100')" />
          <circle class="rp-pulse rp-d3 text-lp-fg" r="3" fill="currentColor" opacity="0" style="offset-path:path('M52 160 C 140 160, 190 124, 226 106')" />

          <!-- recall flows back out -->
          <circle class="rp-return text-lp-accent" r="3" fill="currentColor" opacity="0" style="offset-path:path('M52 34 C 140 34, 190 70, 226 88')" />
          <circle class="rp-return rp-d5 text-lp-accent" r="3" fill="currentColor" opacity="0" style="offset-path:path('M52 160 C 140 160, 190 124, 226 106')" />

          <g class="rp-warn text-(--lp-warn)">
            <text x="162" y="99" font-size="12" fill="currentColor">⚠</text>
            <text x="146" y="114" font-size="8" fill="currentColor" opacity=".85" font-family="var(--font-mono)">overlap flagged</text>
          </g>
          <text class="rp-tick text-lp-accent" x="278" y="66" font-size="11" fill="currentColor" font-family="var(--font-mono)">✓</text>
        </svg>
      </div>

      <div>
        <h2 class="font-mono text-sm text-lp-fg">▸ four agents, one brain, zero duplicated work</h2>
        <p class="mt-3 max-w-2xl text-sm text-lp-muted">
          you're watching a real run recorded over this repository — {d.workers} workers analyzing
          the claim registry at once. every discovery lands in one shared brain the moment it
          happens; the fleet is flagged <span class="text-(--lp-warn)">⚠</span> the instant two
          workers touch the same file, and a claim only counts once it's verified
          <span class="text-lp-accent">✓</span>.
        </p>
        <p class="mt-3 max-w-2xl text-sm text-lp-muted">
          without a shared brain, agents silently re-discover each other's work. auralis makes
          coordination explicit and cheap — ~2.4ms per event, so the model keeps 99.9% of the
          wall-clock.
        </p>
        <div class="mt-5 flex flex-wrap gap-2 font-mono text-xs">
          <span class="rounded-full border border-lp-border bg-lp-bg/60 px-3 py-1 text-lp-muted">{d.workers} workers · one brain</span>
          <span class="rounded-full border border-lp-border bg-lp-bg/60 px-3 py-1 text-lp-muted"><span class="text-(--lp-warn)">⚠</span> {d.overlapsFlagged} overlaps flagged</span>
          <span class="rounded-full border border-lp-border bg-lp-bg/60 px-3 py-1 text-lp-muted"><span class="text-lp-accent">✓</span> {d.verified} findings verified</span>
        </div>
      </div>
    </div>
  </div>
  </div>
</section>
<style>
  /* lead diagram — findings pulse into the brain, w2+w3 collide and get
     flagged, recall flows back. base state = the finished picture: lanes,
     nodes, the flag and the tick all visible; only the pulses rest hidden. */
  .rp-pulse {
    animation: rp-travel 7s linear infinite;
  }
  .rp-d2 {
    animation-delay: 1.4s;
  }
  .rp-d3 {
    animation-delay: 2.8s;
  }
  @keyframes rp-travel {
    0% { offset-distance: 0%; opacity: 0; }
    2% { opacity: 0.9; }
    19% { opacity: 0.9; }
    22%, 100% { offset-distance: 100%; opacity: 0; }
  }
  .rp-return {
    animation: rp-recall 7s linear infinite;
    animation-delay: 4.2s;
  }
  .rp-d5 {
    animation-delay: 4.7s;
  }
  @keyframes rp-recall {
    0% { offset-distance: 100%; opacity: 0; }
    2% { opacity: 0.9; }
    19% { opacity: 0.9; }
    22%, 100% { offset-distance: 0%; opacity: 0; }
  }
  .rp-warn {
    animation: rp-warn 7s ease-in-out infinite;
  }
  @keyframes rp-warn {
    0%, 38% { opacity: 0; }
    46%, 60% { opacity: 1; }
    70%, 100% { opacity: 0; }
  }
  .rp-tick {
    animation: rp-tick 7s ease-in-out infinite;
  }
  @keyframes rp-tick {
    0%, 20% { opacity: 0; }
    26%, 90% { opacity: 0.95; }
    100% { opacity: 0; }
  }
  .rp-ring {
    transform-box: fill-box;
    transform-origin: center;
    animation: rp-ring 3.5s ease-out infinite;
  }
  @keyframes rp-ring {
    0% { transform: scale(0.35); opacity: 0.6; }
    85%, 100% { transform: scale(1.25); opacity: 0; }
  }

  /* the terminal caret — JS parks it on the newest landed line */
  .rp-caret {
    display: inline-block;
    margin-left: 3px;
    color: var(--lp-accent);
    animation: rp-blink 1.1s linear infinite;
  }
  @keyframes rp-blink {
    0%, 45% { opacity: 1; }
    50%, 95% { opacity: 0; }
    100% { opacity: 1; }
  }
</style>

<script>
  // The Replay — data time is linear against the recorded log's virtual clock
  // (48x, always labeled). Counters, the clock and the progress bar step with
  // their events; nothing is eased. Reduced motion: the completed transcript
  // stays as rendered and replay becomes opt-in (user-initiated motion is ok).
  const SPEED = 48
  const HOLD_MS = 2200
  const list = document.getElementById('replay-list')
  const toggle = document.getElementById('replay-toggle')
  const progress = document.getElementById('replay-progress')
  const clock = document.getElementById('replay-clock')
  const caret = document.getElementById('replay-caret')

  const fmt = (s: number) =>
    `${String(Math.floor(s / 60)).padStart(2, '0')}:${String(s % 60).padStart(2, '0')}`

  if (list && toggle) {
    const rows = [...list.querySelectorAll<HTMLLIElement>('li[data-t]')]
    const counters = {
      finding: document.querySelector<HTMLElement>('[data-counter="finding"]'),
      overlap: document.querySelector<HTMLElement>('[data-counter="overlap"]'),
      verified: document.querySelector<HTMLElement>('[data-counter="verified"]'),
    }
    const finals = {
      finding: counters.finding?.textContent ?? '0',
      overlap: counters.overlap?.textContent ?? '0',
      verified: counters.verified?.textContent ?? '0',
    }
    const finalClock = clock?.textContent ?? '00:00'
    // reserve the pane's final height so replay never shifts layout
    list.style.minHeight = `${list.offsetHeight}px`

    let raf = 0
    let playing = false
    let startedAt = 0
    let pausedElapsed = 0
    let shownSec = -1

    const lastT = Number(rows[rows.length - 1]?.dataset.t ?? 0)
    const setCaret = (on: boolean) => {
      if (caret) caret.style.display = on ? '' : 'none'
    }

    const paint = (elapsed: number) => {
      const vt = elapsed * SPEED
      let f = 0, o = 0, v = 0
      let landedLast: HTMLLIElement | null = null
      for (const row of rows) {
        const landed = Number(row.dataset.t) <= vt
        row.style.visibility = landed ? 'visible' : 'hidden'
        if (landed) {
          if (row.dataset.kind === 'finding') f++
          if (row.dataset.kind === 'overlap') o++
          if (row.dataset.v) v++
          landedLast = row
        }
      }
      if (counters.finding) counters.finding.textContent = String(f)
      if (counters.overlap) counters.overlap.textContent = String(o)
      if (counters.verified) counters.verified.textContent = String(v)
      if (progress) progress.style.transform = `scaleX(${Math.min(vt / lastT, 1)})`
      if (clock) {
        const s = Math.min(Math.floor(vt / 1000), Math.floor(lastT / 1000))
        if (s !== shownSec) {
          shownSec = s
          clock.textContent = fmt(s)
        }
      }
      if (caret && landedLast && caret.parentElement !== landedLast) landedLast.appendChild(caret)
      setCaret(true)
    }

    const showFinal = () => {
      for (const row of rows) row.style.visibility = 'visible'
      if (counters.finding) counters.finding.textContent = finals.finding
      if (counters.overlap) counters.overlap.textContent = finals.overlap
      if (counters.verified) counters.verified.textContent = finals.verified
      if (progress) progress.style.transform = 'scaleX(1)'
      if (clock) clock.textContent = finalClock
      shownSec = -1
      setCaret(false)
    }

    const tick = (now: number) => {
      const elapsed = pausedElapsed + (now - startedAt)
      paint(elapsed)
      if (elapsed * SPEED >= lastT) {
        showFinal()
        raf = window.setTimeout(() => {
          pausedElapsed = 0
          startedAt = performance.now()
          raf = requestAnimationFrame(tick)
        }, HOLD_MS) as unknown as number
        return
      }
      raf = requestAnimationFrame(tick)
    }

    const play = () => {
      playing = true
      toggle.textContent = '▮▮ pause'
      startedAt = performance.now()
      raf = requestAnimationFrame(tick)
    }
    const pause = () => {
      playing = false
      toggle.textContent = '▶ replay'
      pausedElapsed += performance.now() - startedAt
      cancelAnimationFrame(raf)
      clearTimeout(raf)
    }

    toggle.classList.remove('hidden')
    toggle.addEventListener('click', () => (playing ? pause() : play()))

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches
    if (reduced) {
      toggle.textContent = '▶ replay' // opt-in only; transcript already complete
    } else {
      toggle.textContent = '▶ replay'
      // start when visible, pause when hidden — live but calm
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting && !playing) { pausedElapsed = 0; play() }
            else if (!e.isIntersecting && playing) pause()
          }
        },
        { threshold: 0.4 },
      )
      io.observe(list)
      document.addEventListener('visibilitychange', () => {
        if (document.hidden && playing) pause()
      })
    }
  }
</script>
