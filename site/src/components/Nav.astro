---
// hideNarrow: the full set needs ~417px — wider than a 390px phone. proof,
// start, and github survive the cut; architecture/docs return at sm:.
const links: Array<[string, string, boolean?]> = [
  ['proof', '#proof'],
  ['architecture', '#architecture', true],
  ['start', '#start'],
  ['docs', 'https://github.com/itoonx/Auralis/tree/main/docs', true],
  ['github ↗', 'https://github.com/itoonx/Auralis'],
]
---

<!-- fixed, not sticky: the nav sits outside the ScrollSmoother wrapper, and
     sticky positioning can't track a transform-scrolled content block -->
<!-- glass nav: bg/90 made the blur invisible — a lower veil + stronger blur
     lets the particle field read through while text stays legible -->
<nav class="fixed inset-x-0 top-0 z-10 border-b border-lp-border bg-lp-bg/55 backdrop-blur-xl backdrop-saturate-150" aria-label="primary">
  <div class="mx-auto flex max-w-6xl items-baseline justify-between px-6 py-3">
    <a href="#top" class="font-sans text-sm font-medium lowercase text-lp-fg">auralis</a>
    <div class="flex gap-3 font-mono text-xs text-lp-muted sm:gap-5">
      {links.map(([label, href, hideNarrow]) => (
        <a
          class:list={['underline-offset-4 hover:text-lp-fg hover:underline', hideNarrow && 'hidden sm:inline']}
          href={href}>{label}</a>
      ))}
    </div>
  </div>
</nav>
