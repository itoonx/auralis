---
import '../styles/global.css'

// base-aware links: GitHub Pages serves any missing path's 404 from here,
// so "back home" must point at the deployed base, not the web root
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#101010" />
    <meta name="robots" content="noindex" />
    <title>404 — auralis</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body>
    <main class="mx-auto flex min-h-screen max-w-xl flex-col items-start justify-center gap-4 px-6 font-mono">
      <p class="text-sm text-lp-muted">⚠ 404 — no such route. stated plainly, not dressed up.</p>
      <a href={base} class="text-sm text-lp-fg underline-offset-4 hover:underline">← back to auralis</a>
    </main>
  </body>
</html>
