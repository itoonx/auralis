---
import '../styles/global.css'
import Field from '../components/Field.astro'
import Nav from '../components/Nav.astro'
import Motion from '../components/Motion.astro'
import Hero from '../components/Hero.astro'
import Replay from '../components/Replay.astro'
import Problem from '../components/Problem.astro'
import Bet from '../components/Bet.astro'
import Proof from '../components/Proof.astro'
import Architecture from '../components/Architecture.astro'
import Memory from '../components/Memory.astro'
import Coordination from '../components/Coordination.astro'
import BuildMode from '../components/BuildMode.astro'
import Studio from '../components/Studio.astro'
import Mcp from '../components/Mcp.astro'
import GettingStarted from '../components/GettingStarted.astro'
import Limits from '../components/Limits.astro'
import Footer from '../components/Footer.astro'

import geistUrl from '@fontsource-variable/geist/files/geist-latin-wght-normal.woff2?url'
import geistMonoUrl from '@fontsource-variable/geist-mono/files/geist-mono-latin-wght-normal.woff2?url'
import serifUrl from '@fontsource-variable/cormorant-garamond/files/cormorant-garamond-latin-wght-normal.woff2?url'
import serifItalicUrl from '@fontsource-variable/cormorant-garamond/files/cormorant-garamond-latin-wght-italic.woff2?url'

const title = 'auralis — the coordination layer for ai agent fleets'
const description =
  'redundant work −53% on a live run. one shared, persistent brain + real-time coordination for fleets of AI coding agents — measured, not asserted.'
// base-aware absolute URLs — on GitHub Pages the site lives under /Auralis,
// so nothing may assume the web root (BASE_URL has no trailing slash there)
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
const canonical = new URL(base, Astro.site)

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'auralis',
  description,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Linux',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  license: 'https://github.com/itoonx/Auralis/blob/main/LICENSE',
  sameAs: ['https://github.com/itoonx/Auralis'],
})
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#101010" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(`${base}og.png`, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preload" href={geistUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={geistMonoUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={serifUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={serifItalicUrl} as="font" type="font/woff2" crossorigin />
    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </head>
  <body id="top">
    <!-- first focusable on the page: with a fixed nav that shadows every
         anchor jump, an explicit skip link beats landmark-only bypass -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:border focus:border-lp-border focus:bg-lp-surface focus:px-4 focus:py-2 focus:font-mono focus:text-sm focus:text-lp-fg"
      >skip to content</a>
    <!-- fixed layers (field canvas, nav) stay OUTSIDE the smoother wrapper:
         ScrollSmoother transforms #smooth-content, and position:fixed inside
         a transformed ancestor degrades to absolute -->
    <Field />
    <Nav />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <main id="main" tabindex="-1" class="outline-none">
          <Hero />
          <Replay />
          <Problem />
          <Bet />
          <Proof />
          <Architecture />
          <Memory />
          <Coordination />
          <BuildMode />
          <Studio />
          <Mcp />
          <GettingStarted />
          <Limits />
        </main>
        <Footer />
      </div>
    </div>
    <Motion />
  </body>
</html>
