# ── auralis configuration ─────────────────────────────────────────────────────
# Everything project-specific comes from env vars, so auralis isn't tied to any repo.
# All values below are optional; the defaults shown make `pnpm dev` work out of the box.

# ── target & goal ─────────────────────────────────────────────────────────────
AURALIS_PROJECT_DIR=/path/to/your/repo   # the codebase the fleet analyses (default: cwd)
AURALIS_PROJECT=default                  # brain namespace/tag; recall is scoped to it
AURALIS_GOAL=Understand this codebase end-to-end: architecture, core modules, main flow, error handling.
AURALIS_TASKS=                           # fixed task set (inline JSON array or a path) — bypasses the Planner
AURALIS_OUT=./.auralis-out               # where traces + provenance are written

# ── fleet behavior ────────────────────────────────────────────────────────────
AURALIS_PARALLEL=1                       # 1 = sequential (max sharing); >1 = per-level concurrency (faster)
AURALIS_RETRIES=1                        # Critic self-repair retries per task (0 = off)
AURALIS_MAX_TURNS=10                     # per-worker Claude Code turn cap
AURALIS_PLAN_TURNS=6                     # Planner turn cap
AURALIS_WORKER_PULL=0                    # 1 = workers call the brain directly as an MCP tool
AURALIS_TRIALS=1                         # pnpm bench: number of trials to average

# ── knowledge lifecycle (all default OFF → free heuristics; ON → Claude Code / real embeddings) ──
AURALIS_SEMANTIC=0                        # 1 = real sentence embeddings via the Node embed-sidecar
AURALIS_COGNIFY=0                        # 1 = build the graph on ingest, as findings land
AURALIS_COGNIFY_LLM=0                     # 1 = pnpm cognify extracts real predicates via Claude Code
AURALIS_DISTILL_LLM=0                     # 1 = pnpm distill merges clusters via Claude Code
AURALIS_DISTILL_THRESHOLD=0.55           # cosine similarity to cluster findings for distillation

# ── oracle-lite brain sidecar ─────────────────────────────────────────────────
ORACLE_API_URL=http://localhost:47778    # where the adapter reaches the brain
ORACLE_DB=.auralis-out/brain.sqlite      # brain database path
ORACLE_EMBED_URL=                         # embed-sidecar URL (auto-set when AURALIS_SEMANTIC=1)
# ORACLE_NO_VECTORS=1                     # disable the LanceDB vector layer (FTS-only)
# ORACLE_ALLOW_RESET=1                    # enable POST /api/reset (bench only — off by default; no delete)

# ── embed-sidecar ─────────────────────────────────────────────────────────────
EMBED_PORT=47779                          # port for the semantic embedding sidecar
