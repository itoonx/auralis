# auralis configuration — works against any codebase
AURALIS_PROJECT_DIR=.                    # the repo the Claude Code workers explore
AURALIS_PROJECT=default                  # namespacing tag for the shared brain
# AURALIS_TASK_A="Explain the core architecture of this codebase. Be concise."
# AURALIS_TASK_B="Trace the primary end-to-end flow, module by module. Be concise."
ORACLE_API_URL=http://localhost:47778    # shared-brain sidecar base URL
AURALIS_OUT=./.auralis-out               # where run traces are written
AURALIS_MAX_TURNS=12                     # per-worker turn cap
AURALIS_GOAL="Understand this codebase end-to-end: architecture, core modules, primary flow, error handling."
AURALIS_PLAN_TURNS=6                      # turn cap for the planning run
